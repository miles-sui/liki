{
  "name": "query_huangli_bond_date",
  "description": "结合八字在指定日期范围内择日。返回：吉日列表及与八字的匹配度。",
  "parameters": {
    "type": "object",
    "properties": {
      "birth": {
        "type": "object",
        "description": "出生信息",
        "properties": {
          "time": {
            "type": "string",
            "description": "公历出生时间，RFC3339格式。与lunar二选一"
          },
          "longitude": {
            "type": "number",
            "description": "出生地经度"
          }
        },
        "required": [
          "time",
          "longitude"
        ]
      },
      "event_type": {
        "type": "string",
        "description": "择日类型，如 嫁娶、入宅"
      },
      "date": {
        "type": "string",
        "description": "日期，格式 YYYY-MM-DD"
      }
    },
    "required": [
      "birth",
      "event_type",
      "date"
    ]
  }
}
