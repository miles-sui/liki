{
  "name": "compute_liuri",
  "description": "计算指定日期的流日运势分析。返回：流日干支、十神、纳音、与命局的互动关系、与流年大运的互动、神煞。当用户询问某日运势时调用。",
  "parameters": {
    "type": "object",
    "properties": {
      "date": {"type": "string", "description": "要分析的日期，YYYY-MM-DD 格式，如 2026-06-17"},
      "birth": {
        "type": "object",
        "description": "出生信息。time（公历）和lunar（农历）二选一",
        "properties": {
          "time": {"type": "string", "description": "公历出生时间，RFC3339格式。与lunar二选一"},
          "lunar": {
            "type": "object",
            "properties": {
              "year": {"type": "integer"}, "month": {"type": "integer"}, "day": {"type": "integer"},
              "hour": {"type": "integer"}, "minute": {"type": "integer"}, "leap": {"type": "boolean"}
            },
            "required": ["year", "month", "day", "hour"]
          },
          "longitude": {"type": "number", "description": "出生地经度"}
        },
        "anyOf": [
          {"required": ["time", "longitude"]},
          {"required": ["lunar", "longitude"]}
        ]
      },
      "dayun": {
        "type": "object",
        "description": "当前大运的干支信息，可选。{Gan: int, Zhi: int}，Gan 1-10，Zhi 1-12"
      },
      "liunian": {
        "type": "object",
        "description": "当前流年的干支信息，可选。{Gan: int, Zhi: int}，Gan 1-10，Zhi 1-12"
      }
    },
    "required": ["date", "birth"]
  }
}
