{
  "name": "compute_bazhai",
  "description": "根据出生参数计算八宅风水命盘。返回：东西四命、伏位/生气/天医/延年/祸害/六煞/五鬼/绝命八星方位。",
  "parameters": {
    "type": "object",
    "properties": {
      "birth": {
        "type": "object",
        "description": "出生信息",
        "properties": {
          "time": {
            "type": "string",
            "description": "公历出生时间，RFC3339格式。与lunar二选一"
          },
          "longitude": {
            "type": "number",
            "description": "出生地经度"
          }
        },
        "required": [
          "time",
          "longitude"
        ]
      },
      "gender": {
        "type": "string",
        "enum": [
          "male",
          "female"
        ]
      }
    },
    "required": [
      "birth",
      "gender"
    ]
  }
}
