{
  "name": "compute_chart",
  "description": "根据出生参数计算完整八字命盘。你自己不会排八字、定格局、推用神——必须通过此工具获取所有计算数据。返回：四柱（天干地支）、十神、藏干、纳音、神煞、五行分布、用神（扶抑+调候）、格局、大运。",
  "parameters": {
    "type": "object",
    "properties": {
      "birth": {
        "type": "object",
        "description": "出生信息。time（公历）和lunar（农历）二选一",
        "properties": {
          "time": {"type": "string", "description": "公历出生时间，RFC3339格式，如 1990-06-15T12:00:00+08:00。与lunar二选一"},
          "lunar": {
            "type": "object",
            "description": "农历出生日期。与time二选一",
            "properties": {
              "year": {"type": "integer", "description": "农历年，如 1984"},
              "month": {"type": "integer", "description": "农历月 1-12"},
              "day": {"type": "integer", "description": "农历日 1-30"},
              "hour": {"type": "integer", "description": "出生小时 0-23"},
              "minute": {"type": "integer", "description": "出生分钟 0-59"},
              "leap": {"type": "boolean", "description": "是否闰月"}
            },
            "required": ["year", "month", "day", "hour"]
          },
          "longitude": {"type": "number", "description": "出生地经度，如 116.4（东经为正）"}
        },
        "anyOf": [
          {"required": ["time", "longitude"]},
          {"required": ["lunar", "longitude"]}
        ]
      },
      "gender": {"type": "string", "enum": ["male", "female"]}
    },
    "required": ["birth", "gender"]
  }
}
