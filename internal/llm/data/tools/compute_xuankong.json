{
  "name": "compute_xuankong",
  "description": "计算玄空飞星盘。根据时间和山向排出玄空飞星宅命盘。当用户询问玄空风水、飞星布局、山向飞星时调用。",
  "parameters": {
    "type": "object",
    "properties": {
      "birth": {
        "type": "object",
        "description": "出生信息",
        "properties": {
          "time": {
            "type": "string",
            "description": "公历出生时间，RFC3339格式。与lunar二选一"
          },
          "longitude": {
            "type": "number",
            "description": "出生地经度"
          }
        },
        "required": [
          "time",
          "longitude"
        ]
      },
      "sit_mountain": {
        "type": "integer",
        "description": "坐山索引 0-23，对应二十四山"
      },
      "face_mountain": {
        "type": "integer",
        "description": "朝向索引 0-23，对应二十四山"
      }
    },
    "required": [
      "birth",
      "sit_mountain",
      "face_mountain"
    ]
  }
}
