{
  "name": "compute_xiaoyun",
  "description": "计算小运（童年运势）。返回每年干支、十神。当用户询问小运或幼年运势时调用。",
  "parameters": {
    "type": "object",
    "properties": {
      "birth": {
        "type": "object",
        "description": "出生信息",
        "properties": {
          "time": {
            "type": "string",
            "description": "公历出生时间，RFC3339格式。与lunar二选一"
          },
          "longitude": {
            "type": "number",
            "description": "出生地经度"
          }
        },
        "required": [
          "time",
          "longitude"
        ]
      },
      "gender": {
        "type": "string",
        "enum": [
          "male",
          "female"
        ]
      },
      "count": {
        "type": "integer",
        "description": "需要计算的年数，默认 12，最大 120"
      }
    },
    "required": [
      "birth",
      "gender"
    ]
  }
}
