{
  "name": "compute_ziwei",
  "description": "根据出生参数计算紫微斗数完整命盘。返回：十二宫（命宫/兄弟/夫妻/子女/财帛/疾厄/迁移/交友/官禄/田宅/福德/父母）、主星+辅星落宫、四化、格局。当用户询问紫微命盘时调用。",
  "parameters": {
    "type": "object",
    "properties": {
      "birth": {
        "type": "object",
        "description": "出生信息",
        "properties": {
          "time": {
            "type": "string",
            "description": "公历出生时间，RFC3339格式。与lunar二选一"
          },
          "longitude": {
            "type": "number",
            "description": "出生地经度"
          }
        },
        "required": [
          "time",
          "longitude"
        ]
      },
      "gender": {
        "type": "string",
        "enum": [
          "male",
          "female"
        ]
      }
    },
    "required": [
      "birth",
      "gender"
    ]
  }
}
