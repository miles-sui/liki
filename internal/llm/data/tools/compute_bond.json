{
  "name": "compute_bond",
  "description": "计算两人的八字合盘配对分析。你自己不会排盘、分析八字关系——必须通过此工具获取所有计算数据。返回：双方日主、天干关系（合/生/克）、地支关系（六合/三合/六冲）、纳音配合、关键提示。",
  "parameters": {
    "type": "object",
    "properties": {
      "a": {
        "type": "object",
        "description": "甲方信息",
        "properties": {
          "birth": {
            "type": "object",
            "description": "甲方出生信息",
            "properties": {
              "time": {
                "type": "string",
                "description": "公历出生时间，RFC3339格式"
              },
              "longitude": {
                "type": "number",
                "description": "出生地经度，如 116.4"
              }
            },
            "required": [
              "time",
              "longitude"
            ]
          },
          "gender": {
            "type": "string",
            "enum": [
              "male",
              "female"
            ]
          }
        },
        "required": [
          "birth",
          "gender"
        ]
      },
      "b": {
        "type": "object",
        "description": "乙方信息",
        "properties": {
          "birth": {
            "type": "object",
            "description": "乙方出生信息",
            "properties": {
              "time": {
                "type": "string",
                "description": "公历出生时间，RFC3339格式"
              },
              "longitude": {
                "type": "number",
                "description": "出生地经度，如 116.4"
              }
            },
            "required": [
              "time",
              "longitude"
            ]
          },
          "gender": {
            "type": "string",
            "enum": [
              "male",
              "female"
            ]
          }
        },
        "required": [
          "birth",
          "gender"
        ]
      }
    },
    "required": [
      "a",
      "b"
    ]
  }
}
