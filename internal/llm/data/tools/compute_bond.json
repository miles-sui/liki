{
  "name": "compute_bond",
  "description": "计算两人的八字合盘配对分析。你自己不会排盘、分析八字关系——必须通过此工具获取所有计算数据。返回：双方日主、天干关系（合/生/克）、地支关系（六合/三合/六冲）、纳音配合、关键提示。",
  "parameters": {
    "type": "object",
    "properties": {
      "a": {
        "type": "object",
        "description": "甲方信息",
        "properties": {
          "birth": {
            "type": "object",
            "description": "甲方出生信息。time（公历）和lunar（农历）二选一",
            "properties": {
              "time": {"type": "string", "description": "公历出生时间，RFC3339格式"},
              "lunar": {
                "type": "object",
                "properties": {
                  "year": {"type": "integer", "description": "农历年"},
                  "month": {"type": "integer", "description": "农历月 1-12"},
                  "day": {"type": "integer", "description": "农历日 1-30"},
                  "hour": {"type": "integer", "description": "出生小时 0-23"},
                  "minute": {"type": "integer", "description": "出生分钟 0-59"},
                  "leap": {"type": "boolean", "description": "是否闰月"}
                },
                "required": ["year", "month", "day", "hour"]
              },
              "longitude": {"type": "number", "description": "出生地经度，如 116.4"}
            },
            "anyOf": [
              {"required": ["time", "longitude"]},
              {"required": ["lunar", "longitude"]}
            ]
          },
          "gender": {"type": "string", "enum": ["male", "female"]}
        },
        "required": ["birth", "gender"]
      },
      "b": {
        "type": "object",
        "description": "乙方信息",
        "properties": {
          "birth": {
            "type": "object",
            "description": "乙方出生信息。time（公历）和lunar（农历）二选一",
            "properties": {
              "time": {"type": "string", "description": "公历出生时间，RFC3339格式"},
              "lunar": {
                "type": "object",
                "properties": {
                  "year": {"type": "integer", "description": "农历年"},
                  "month": {"type": "integer", "description": "农历月 1-12"},
                  "day": {"type": "integer", "description": "农历日 1-30"},
                  "hour": {"type": "integer", "description": "出生小时 0-23"},
                  "minute": {"type": "integer", "description": "出生分钟 0-59"},
                  "leap": {"type": "boolean", "description": "是否闰月"}
                },
                "required": ["year", "month", "day", "hour"]
              },
              "longitude": {"type": "number", "description": "出生地经度，如 116.4"}
            },
            "anyOf": [
              {"required": ["time", "longitude"]},
              {"required": ["lunar", "longitude"]}
            ]
          },
          "gender": {"type": "string", "enum": ["male", "female"]}
        },
        "required": ["birth", "gender"]
      }
    },
    "required": ["a", "b"]
  }
}
