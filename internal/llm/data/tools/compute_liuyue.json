{
  "name": "compute_liuyue",
  "description": "计算指定年月的流月运势分析。返回：流月干支、十神、五行生克、与命局的互动关系、神煞。当用户询问某月运势时调用。",
  "parameters": {
    "type": "object",
    "properties": {
      "year": {"type": "integer", "description": "要分析的年份，如 2026"},
      "month": {"type": "integer", "description": "要分析的月份 1-12"},
      "birth": {
        "type": "object",
        "description": "出生信息。time（公历）和lunar（农历）二选一",
        "properties": {
          "time": {"type": "string", "description": "公历出生时间，RFC3339格式。与lunar二选一"},
          "lunar": {
            "type": "object",
            "properties": {
              "year": {"type": "integer"}, "month": {"type": "integer"}, "day": {"type": "integer"},
              "hour": {"type": "integer"}, "minute": {"type": "integer"}, "leap": {"type": "boolean"}
            },
            "required": ["year", "month", "day", "hour"]
          },
          "longitude": {"type": "number", "description": "出生地经度"}
        },
        "anyOf": [
          {"required": ["time", "longitude"]},
          {"required": ["lunar", "longitude"]}
        ]
      }
    },
    "required": ["year", "month", "birth"]
  }
}
