{
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(npm *)",
      "Bash(git *)",
      "Bash(scripts/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_FILE_PATH\" | grep -q '\\.go$' && goimports -w \"$CLAUDE_FILE_PATH\" || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qiE '(api[_-]?key|secret|token|password|DEEPSEEK_API_KEY|DODO_API_KEY|RESEND_API_KEY|JWT_SECRET) *= *[a-zA-Z0-9_\\-]{20,}'; then echo '[block-secrets] 疑似密钥写入，已拦截' >&2; exit 2; fi"
          }
        ]
      }
    ]
  }
}
