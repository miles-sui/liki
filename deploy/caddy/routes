# 25types — Shared Route Rules (imported by Caddyfile and Caddyfile.dev)
# This file contains deployment-specific config (root, API proxies, rate limits)
# and imports the shared static routes used by both prod and local dev.

root * /app/frontend/dist
encode gzip

# Rate limit zones (prod only: thresholds are high enough to be no-op in dev)
rate_limit {
    zone auth {
        match {
            path /api/auth/*
        }
        key {remote_ip}
        events 20
        window 1m
    }
    zone assess {
        match {
            path /api/assessments
        }
        key {remote_ip}
        events 30
        window 1m
    }
}

# Auth endpoints
reverse_proxy /api/auth/* backend:8080

# Assessment submission
reverse_proxy /api/assessments backend:8080

# All other API, no rate limit
reverse_proxy /api/* backend:8080

import static_routes
