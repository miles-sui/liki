{$DOMAIN:localhost} {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloudflareinsights.com; object-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'self'"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		-Server
	}

	# Cache static assets
	header /js/* Cache-Control "public, max-age=31536000, immutable"
	header /css/* Cache-Control "public, max-age=31536000, immutable"
	header /i18n/* Cache-Control "public, max-age=60"

	log {
		output stdout
		format json
	}

	# Protected routes — require same-origin
	handle /api/agent/* {
		@external {
			header Origin *
			not header Origin https://{$DOMAIN:localhost}
		}
		respond @external 403
		reverse_proxy liki:8080 {
			flush_interval -1
		}
	}
	handle /api/orders/*/retry {
		@external {
			header Origin *
			not header Origin https://{$DOMAIN:localhost}
		}
		respond @external 403
		reverse_proxy liki:8080
	}

	# JSON-RPC for external AI agents — no Origin check
	handle /jsonrpc {
		reverse_proxy liki:8080
	}

	# Free API, health — no Origin check
	handle /api/* {
		reverse_proxy liki:8080 {
			flush_interval -1
			health_uri /api/health
			health_interval 30s
			health_timeout 5s
		}
	}

	# Standard BCP 47 paths
	redir /zh-Hans  /zh-Hans/ 308
	redir /zh-Hant  /zh-Hant/ 308
	redir /en  /en/ 308

	# Legacy redirects: old locale paths → new BCP 47 paths
	redir /zh  /zh-Hans/ 308
	redir /hk  /zh-Hant/ 308
	@zh-legacy path_regexp zh ^/zh/(.*)
	redir @zh-legacy /zh-Hans/{re.zh.1} 308
	@hk-legacy path_regexp hk ^/hk/(.*)
	redir @hk-legacy /zh-Hant/{re.hk.1} 308

	handle_path /zh-Hans/report/* {
		root * /srv/web
		try_files /report.html
	}
	handle_path /zh-Hant/report/* {
		root * /srv/web
		try_files /report.html
	}
	handle_path /en/report/* {
		root * /srv/web
		try_files /report.html
	}

	handle_path /zh-Hans/* {
		root * /srv/web
		try_files {path} {path}.html /index.html
	}
	handle_path /zh-Hant/* {
		root * /srv/web
		try_files {path} {path}.html /index.html
	}
	handle_path /en/* {
		root * /srv/web
		try_files {path} {path}.html /index.html
	}

	handle_path /report/* {
		root * /srv/web
		try_files /report.html
	}

	route {
		root * /srv/web
		try_files {path} {path}.html /index.html
		file_server
	}
}
