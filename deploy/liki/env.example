# Liki Environment Variables
# Copy to deploy/liki/.env and fill in values

# Server
LISTEN_ADDR=:8080
DB_PATH=/var/lib/liki/liki.db

# Domain (for Caddy)
DOMAIN=liki.hk

# DeepSeek AI
DEEPSEEK_API_KEY=sk-your-key-here

# Dodo Payments (国际卡)
DODO_API_KEY=
DODO_WEBHOOK_KEY=
DODO_TEST_MODE=true
DODO_PRODUCT_NAMING=

# 虎皮椒支付 (微信/支付宝)
XUNHU_APPID=
XUNHU_APPSECRET=

# Resend Email
RESEND_API_KEY=
RESEND_FROM="Liki <noreply@mail.tokflux.com>"

# Payment
RETURN_URL_US=https://liki.hk
RETURN_URL_CN=https://liki.hk
RETURN_URL=https://liki.hk

# Cloudflare (optional, for TLS)
CF_API_TOKEN=
