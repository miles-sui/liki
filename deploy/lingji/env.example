# LingJi Environment Variables
# Copy to deploy/lingji/.env and fill in values

# Server
LISTEN_ADDR=:8080
DB_PATH=/var/lib/lingji/lingji.db
PDF_DIR=/var/lib/lingji/pdfs

# Domain (for Caddy)
DOMAIN=liki.hk

# DeepSeek AI
DEEPSEEK_API_KEY=sk-your-key-here

# Dodo Payments
DODO_API_KEY=
DODO_WEBHOOK_KEY=
DODO_TEST_MODE=true

# Dodo Product IDs (format: product:currency → product_id)
DODO_PRODUCT_CHART_CNY=
DODO_PRODUCT_CHART_USD=
DODO_PRODUCT_BOND_CNY=
DODO_PRODUCT_BOND_USD=
DODO_PRODUCT_NAMING_CNY=
DODO_PRODUCT_NAMING_USD=

# Resend Email
RESEND_API_KEY=
RESEND_FROM="LingJi <noreply@mail.tokflux.com>"

# Payment
RETURN_URL=https://liki.hk

# Cloudflare (optional, for TLS)
CF_API_TOKEN=
