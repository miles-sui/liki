# LingJi Environment Variables
# Copy to deploy/lingji/.env and fill in values

# Server
LISTEN_ADDR=:8080
DB_PATH=/var/lib/lingji/lingji.db
PDF_DIR=/var/lib/lingji/pdfs

# Domain (for Caddy)
DOMAIN=liki.hk

# DeepSeek AI
DEEPSEEK_API_KEY=sk-your-key-here

# Dodo Payments (国际卡)
DODO_API_KEY=
DODO_WEBHOOK_KEY=
DODO_TEST_MODE=true
DODO_PRODUCT_CHART=
DODO_PRODUCT_BOND=
DODO_PRODUCT_NAMING=

# 虎皮椒支付 (微信/支付宝)
XUNHU_APPID=
XUNHU_APPSECRET=

# Resend Email
RESEND_API_KEY=
RESEND_FROM="LingJi <noreply@mail.tokflux.com>"

# Payment
RETURN_URL=https://liki.hk

# Cloudflare (optional, for TLS)
CF_API_TOKEN=
