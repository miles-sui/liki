<div class="card bg-base-200 shadow-sm">
  <div class="card-body items-center text-center p-5">
    <div class="badge badge-outline badge-sm mb-1" x-text="{{ badge }}"></div>
    <h4 class="text-lg font-bold" x-text="{{ label }}"></h4>
    <p class="text-xs text-base-content/50 font-mono mb-3" x-text="{{ idText }}"></p>
    {% set _outerCls = chartCls %}{% set chartCls = chartCls | default('chart-h-260') %}{% set id = chartId %}{% include "chart-container.njk" %}{% set chartCls = _outerCls %}
    <p class="text-xs text-base-content/40 mt-1 mb-2">
      ← <span class="font-medium" x-text="{{ influencerLabel }}"></span>
    </p>
    {% set items = deltaItems %}{% set deltaCls = 'mt-1 w-full' %}{% include "element-delta-bars.njk" %}
  </div>
</div>
