<!-- _head.html — shared <head> content -->
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title | default("25types — Life Answer Engine") }}</title>
<meta name="description" content="{{ description | default('Computable personality & relationship analysis. Free assessment.') }}">
<meta property="og:title" content="{{ title | default('25types — Life Answer Engine') }}">
<meta property="og:description" content="{{ description | default('Computable personality & relationship analysis. Free assessment.') }}">
<meta property="og:type" content="website">
<meta property="og:image" content="{{ ogImage | default('/img/og-default.png') }}">
<meta property="og:url" content="{{ ogUrl | default(page.url) | default('https://25types.com') }}">
<meta name="twitter:card" content="summary_large_image">
<link rel="stylesheet" href="/css/tailwind.min.css">
<link rel="stylesheet" href="https://fontsapi.zeoseven.com/820/main/result.css">
<link rel="icon" type="image/svg+xml" href="/img/favicon.svg?v=2">
<script src="/js/vendor/alpine.min.js" defer></script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "25types",
  "url": "https://25types.com",
  "description": "{{ description | default('A computable personality & relationship analysis platform.') | e }}",
  "inLanguage": ["en", "zh-CN"]
}
</script>

