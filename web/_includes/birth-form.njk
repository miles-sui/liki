<div class="space-y-4">
  <!-- Birthplace: city search → auto-fills lon/tz -->
  <div class="form-control relative">
    <label class="label"><span class="label-text" x-text="$store.locale.t('mingli.bazi.city')">Birthplace</span></label>
    <input type="text" class="input input-bordered" x-model="cityQuery" @input="filterCities()" @focus="showCityList = true" :placeholder="$store.locale.t('mingli.bazi.cityPlaceholder')">
    <ul class="absolute z-10 bg-base-100 border border-base-300 rounded w-full max-h-48 overflow-y-auto shadow-lg" x-show="showCityList && filteredCities.length > 0" @click.away="showCityList = false" style="top: 100%;">
      <template x-for="c in filteredCities" :key="c.name + c.country">
        <li class="px-3 py-2 hover:bg-base-200 cursor-pointer text-sm" @click="selectCity(c)" x-text="cityDisplayName(c)"></li>
      </template>
    </ul>

    <!-- Selected city → derived coordinates -->
    <template x-if="selectedCityName">
      <div class="text-sm text-base-content/60 mt-1" x-text="selectedCityName + ' — ' + $store.locale.t('mingli.bazi.lon') + ': ' + birth.longitude.toFixed(2) + '°  ' + $store.locale.t('mingli.bazi.tz') + ': ' + birth.timezone.toFixed(0) + '°'"></div>
    </template>

    <!-- Manual override (collapsed) -->
    <details class="text-sm mt-2">
      <summary class="cursor-pointer text-base-content/60" x-text="$store.locale.t('mingli.bazi.manualCoords')">Manual coordinates</summary>
      <div class="grid grid-cols-2 gap-4 mt-3 p-3 bg-base-100 rounded">
        <div class="form-control">
          <label class="label"><span class="label-text" x-text="$store.locale.t('mingli.bazi.longitude')">Longitude</span></label>
          <input type="number" class="input input-bordered input-sm" x-model.number="birth.longitude" step="0.01" placeholder="120.0">
        </div>
        <div class="form-control">
          <label class="label"><span class="label-text" x-text="$store.locale.t('mingli.bazi.timezone')">Timezone</span></label>
          <input type="number" class="input input-bordered input-sm" x-model.number="birth.timezone" step="0.01" placeholder="120.0">
        </div>
      </div>
    </details>
  </div>

  <!-- DST -->
  <div class="form-control">
    <label class="label cursor-pointer gap-2">
      <span class="label-text" x-text="$store.locale.t('mingli.bazi.isDST')">DST</span>
      <span class="label-text-alt opacity-50" x-text="$store.locale.t('mingli.bazi.dstHint')">1986-1991</span>
      <input type="checkbox" class="toggle toggle-primary toggle-sm" x-model="birth.is_dst">
    </label>
  </div>

  <div class="form-control">
    <label class="label"><span class="label-text font-medium" x-text="$store.locale.t('mingli.bazi.datetime')">Date & Time</span></label>
    <div class="join mb-2" x-show="showLunar">
      <button class="join-item btn btn-sm" :class="calendarType === 'solar' ? 'btn-primary' : 'btn-ghost'" @click="calendarType = 'solar'; parseBirthDatetime(birthDate, birthTime, birth)" x-text="$store.locale.t('mingli.bazi.solar')">Gregorian</button>
      <button class="join-item btn btn-sm" :class="calendarType === 'lunar' ? 'btn-primary' : 'btn-ghost'" @click="calendarType = 'lunar'; setLunarDate()" x-text="$store.locale.t('mingli.bazi.lunar')">Lunar</button>
    </div>

    <div x-show="calendarType === 'solar'" class="grid grid-cols-2 gap-3">
      <input type="date" class="input input-bordered" x-model="birthDate" max="2100-12-31" min="1900-01-01" @change="parseBirthDatetime(birthDate, birthTime, birth)">
      <input type="text" class="input input-bordered" x-model="birthTime" placeholder="00:00" maxlength="5" inputmode="numeric" autocomplete="off" @blur="birthTime = normalizeTime(birthTime)" @change="birthTime = normalizeTime(birthTime)">
    </div>

    <div x-show="calendarType === 'lunar'" class="space-y-2">
      <div class="text-sm text-base-content/70" x-text="lunarDateDisplay(lunarYear, lunarMonth > 100 ? lunarMonth - 100 : lunarMonth, lunarDay, lunarMonth > 100)"></div>
      <div class="grid grid-cols-3 gap-2">
        <input type="number" class="input input-bordered input-sm" x-model.number="lunarYear" min="1900" max="2100" @change="setLunarDate()" placeholder="1984">
        <select class="select select-bordered select-sm" x-model.number="lunarMonth" @change="setLunarDate()">
          <option value="1">正月</option><option value="2">二月</option><option value="3">三月</option><option value="4">四月</option><option value="5">五月</option><option value="6">六月</option>
          <option value="7">七月</option><option value="8">八月</option><option value="9">九月</option><option value="10">十月</option><option value="11">十一月</option><option value="12">十二月</option>
          <option value="101" x-show="lunarGetLeapMonth(lunarYear) === 1">闰正月</option>
          <option value="102" x-show="lunarGetLeapMonth(lunarYear) === 2">闰二月</option>
          <option value="103" x-show="lunarGetLeapMonth(lunarYear) === 3">闰三月</option>
          <option value="104" x-show="lunarGetLeapMonth(lunarYear) === 4">闰四月</option>
          <option value="105" x-show="lunarGetLeapMonth(lunarYear) === 5">闰五月</option>
          <option value="106" x-show="lunarGetLeapMonth(lunarYear) === 6">闰六月</option>
          <option value="107" x-show="lunarGetLeapMonth(lunarYear) === 7">闰七月</option>
          <option value="108" x-show="lunarGetLeapMonth(lunarYear) === 8">闰八月</option>
          <option value="109" x-show="lunarGetLeapMonth(lunarYear) === 9">闰九月</option>
          <option value="110" x-show="lunarGetLeapMonth(lunarYear) === 10">闰十月</option>
          <option value="111" x-show="lunarGetLeapMonth(lunarYear) === 11">闰十一月</option>
          <option value="112" x-show="lunarGetLeapMonth(lunarYear) === 12">闰十二月</option>
        </select>
        <select class="select select-bordered select-sm" x-model.number="lunarDay" @change="setLunarDate()">
          <option value="1">初一</option><option value="2">初二</option><option value="3">初三</option><option value="4">初四</option><option value="5">初五</option><option value="6">初六</option><option value="7">初七</option><option value="8">初八</option><option value="9">初九</option><option value="10">初十</option>
          <option value="11">十一</option><option value="12">十二</option><option value="13">十三</option><option value="14">十四</option><option value="15">十五</option><option value="16">十六</option><option value="17">十七</option><option value="18">十八</option><option value="19">十九</option><option value="20">二十</option>
          <option value="21">廿一</option><option value="22">廿二</option><option value="23">廿三</option><option value="24">廿四</option><option value="25">廿五</option><option value="26">廿六</option><option value="27">廿七</option><option value="28">廿八</option><option value="29">廿九</option><option value="30">三十</option>
        </select>
      </div>
      <input type="text" class="input input-bordered input-sm w-full" x-model="birthTime" placeholder="00:00" maxlength="5" inputmode="numeric" autocomplete="off" @blur="birthTime = normalizeTime(birthTime)" @change="birthTime = normalizeTime(birthTime)">
      <p class="text-xs text-base-content/50" x-text="birthDate ? $store.locale.t('mingli.bazi.solar') + ': ' + birthDate : ''"></p>
    </div>
  </div>

  <div class="form-control max-w-xs">
    <label class="label"><span class="label-text" x-text="$store.locale.t('mingli.bazi.gender')">Gender</span></label>
    <select class="select select-bordered" x-model="birth.gender">
      <option value="male" x-text="$store.locale.t('mingli.bazi.male')">Male</option>
      <option value="female" x-text="$store.locale.t('mingli.bazi.female')">Female</option>
    </select>
  </div>

</div>
