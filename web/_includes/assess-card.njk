<!-- assess-card.njk — question card with side arrows, responsive layout -->
<template x-if="!loading && !error && !showInterstitial && currentQuestion">
  <div>
    <!-- Question number indicator -->
    <div class="text-sm text-base-content/40 mb-3 text-center">
      <span x-text="$store.locale.t('assess.roundResult')">Question</span>
      <span x-text="currentQIndex + 1 + ' / ' + totalQuestions"></span>
      &mdash; <span x-text="$store.locale.t('assess.progress')">Round</span>
      <span x-text="round + ' / ' + totalRounds"></span>
    </div>

    <div class="flex items-center gap-2 sm:gap-4">
      <!-- Left navigation -->
      <button class="btn btn-ghost btn-sm sm:btn-md btn-circle text-xl sm:text-2xl flex-shrink-0"
        @click="goPrev()" :disabled="!canGoPrev()"
        :class="!canGoPrev() ? 'invisible' : ''">&#10094;</button>

      <!-- Card -->
      <div class="flex-1 min-w-0">
        <div class="card bg-base-200 shadow-sm">
          <div class="card-body overflow-y-auto p-4 sm:p-6 assess-card-body">
            <div class="text-base sm:text-lg font-bold mb-4 sm:mb-6 leading-snug" x-text="currentQuestion.text"></div>
            <p class="text-sm text-base-content/60 mb-3" x-text="$store.locale.t('assess.pickTwo')">Pick the two most like you:</p>
            <div class="flex flex-col gap-2 sm:gap-3">
              <template x-for="(opt, idx) in currentQuestion.options" :key="opt.element">
                <button class="btn justify-start text-left h-auto min-h-[3rem] sm:min-h-[3.5rem] py-2 sm:py-3 px-3 sm:px-4 text-sm sm:text-base"
                  :class="isSelected(currentQuestion.qid, opt.element) ? 'btn-primary' : 'btn-ghost'"
                  @click="toggleSelect(currentQuestion.qid, opt.element)">
                  <span class="text-base-content/40 mr-2 text-xs font-mono flex-shrink-0" x-text="(idx + 1)"></span>
                  <span class="leading-snug" x-text="opt.text"></span>
                </button>
              </template>
            </div>
          </div>
        </div>
      </div>

      <!-- Right navigation or submit -->
      <template x-if="canGoNext()">
        <button class="btn btn-ghost btn-sm sm:btn-md btn-circle text-xl sm:text-2xl flex-shrink-0" @click="goNext()">&#10095;</button>
      </template>
      <template x-if="!canGoNext() && typeof submitRound === 'function'">
        <button class="btn btn-primary btn-sm sm:btn-md flex-shrink-0" @click="submitRound()"
          :disabled="submitting">
          <span x-show="!submitting" class="sm:hidden">&#10003;</span>
          <span x-show="!submitting" class="hidden sm:inline" x-text="$store.locale.t('assess.submit')">Submit Round</span>
          <span x-show="submitting" class="loading loading-spinner loading-xs"></span>
        </button>
      </template>
    </div>

    <!-- Status below -->
    <div class="text-center mt-3 sm:mt-4">
      <span class="text-sm" :class="answersInRound() >= 2 ? 'text-success/70' : 'text-base-content/40'">
        <span x-text="$store.locale.t('assess.selected') + ': ' + answersInRound() + ' / 2'"></span>
      </span>
    </div>
  </div>
</template>
