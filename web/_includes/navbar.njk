<!-- _navbar.html -->
{% set cleanPath = page.url | replace('/' + site.locale, '') %}
{% set currentPage = page.url | replace('/' + site.locale + '/', '') | replace('/', '') %}
<div x-data="{ dropdown: null }">
<nav class="navbar bg-base-200/80 backdrop-blur border-b border-base-300 sticky top-0 z-50 px-4 lg:px-14">
  <div class="navbar-start">
    <a href="/{{ site.locale }}/" class="inline-block px-2 py-1 no-underline">
      {% include "logo.njk" %}
    </a>
  </div>

  <!-- Desktop: centered pill menu -->
  <div class="navbar-center hidden lg:flex flex-1 justify-center">
    <div class="flex items-center gap-7 lg:gap-10 bg-base-100/95 border border-base-300 rounded-xl px-7 lg:px-10 py-2 shadow-sm">
      <a href="/{{ site.locale }}/"
         class="relative group text-base-content/90 hover:text-base-content transition-colors text-lg lg:text-xl font-medium whitespace-nowrap {% if currentPage == 'index' %}font-bold text-base-content{% endif %}">
        <span x-text="$store.locale.t('nav.home')">Home</span>
        <span class="absolute left-0 -bottom-0.5 w-0 h-0.5 bg-base-content/60 transition-all duration-200 group-hover:w-full {% if currentPage == 'index' %}w-full{% endif %}"></span>
      </a>
      <a href="/{{ site.locale }}/types"
         class="relative group text-base-content/90 hover:text-base-content transition-colors text-lg lg:text-xl font-medium whitespace-nowrap {% if currentPage == 'types' %}font-bold text-base-content{% endif %}">
        <span x-text="$store.locale.t('nav.types')">Types</span>
        <span class="absolute left-0 -bottom-0.5 w-0 h-0.5 bg-base-content/60 transition-all duration-200 group-hover:w-full {% if currentPage == 'types' %}w-full{% endif %}"></span>
      </a>
      <a href="/{{ site.locale }}/assess"
         class="relative group text-base-content/90 hover:text-base-content transition-colors text-lg lg:text-xl font-medium whitespace-nowrap {% if currentPage == 'assess' %}font-bold text-base-content{% endif %}">
        <span x-text="$store.locale.t('nav.assess')">Assess</span>
        <span class="absolute left-0 -bottom-0.5 w-0 h-0.5 bg-base-content/60 transition-all duration-200 group-hover:w-full {% if currentPage == 'assess' %}w-full{% endif %}"></span>
      </a>
      <!-- Mingli dropdown -->
      <div class="dropdown dropdown-hover">
        <a href="/{{ site.locale }}/mingli/bazi" tabindex="0"
           class="relative group text-base-content/90 hover:text-base-content transition-colors text-lg lg:text-xl font-medium whitespace-nowrap cursor-pointer {% if currentPage == 'mingli-bazi' or currentPage == 'mingli-bazi-match' %}font-bold text-base-content{% endif %}">
          <span x-text="$store.locale.t('nav.mingli.bazi')">Mingli</span>
          <svg class="inline-block w-3 h-3 ml-1 opacity-50" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
          <span class="absolute left-0 -bottom-0.5 h-0.5 bg-base-content/60 transition-all duration-200 {% if currentPage == 'mingli-bazi' or currentPage == 'mingli-bazi-match' %}w-full{% else %}w-0 group-hover:w-full{% endif %}"></span>
        </a>
        <ul tabindex="0" class="dropdown-content menu menu-sm bg-base-200 rounded-box shadow mt-2 z-50 w-48">
          <li><a href="/{{ site.locale }}/mingli/bazi">{% if site.locale == 'zh-CN' %}八字排盘{% else %}Mingli Chart{% endif %}</a></li>
          <li><a href="/{{ site.locale }}/mingli/bazi/liunian">{% if site.locale == 'zh-CN' %}流年运势{% else %}Yearly Fortune{% endif %}</a></li>
          <li><a href="/{{ site.locale }}/qiming/baobao">{% if site.locale == 'zh-CN' %}宝宝起名{% else %}Baby Naming{% endif %}</a></li>
          <li><a href="/{{ site.locale }}/hehun/lianai">{% if site.locale == 'zh-CN' %}恋爱匹配{% else %}Love Match{% endif %}</a></li>
          <li><a href="/{{ site.locale }}/zeri/jiehun">{% if site.locale == 'zh-CN' %}结婚择日{% else %}Wedding Dates{% endif %}</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="navbar-end gap-1 justify-end">
    <!-- city location picker -->
    <div class="dropdown dropdown-end max-lg:hidden" @click.outside="$store.location.searchOpen = false">
      <button class="btn btn-ghost btn-sm text-sm gap-1 px-2" @click="$store.location.searchOpen = !$store.location.searchOpen; if($store.location.searchOpen){ $store.location.searchQuery = ''; $store.location.searchResults = []; }">
        <span>📍</span>
        <span class="max-w-[80px] truncate" x-text="$store.location.hasCity ? $store.location.displayName : ''">City</span>
      </button>
      <div x-show="$store.location.searchOpen" class="dropdown-content bg-base-200 rounded-box shadow mt-2 z-50 w-64 p-3" @click.outside="$store.location.searchOpen = false">
        <input type="text" class="input input-bordered input-sm w-full" :placeholder="$store.locale.t('location.searchPlaceholder')" x-model="$store.location.searchQuery" @input="$store.location.onSearchInput()" autofocus>
        <ul class="menu menu-sm mt-2 max-h-60 overflow-y-auto" x-show="$store.location.searchResults.length > 0">
          <template x-for="c in $store.location.searchResults" :key="c.lat">
            <li><a href="#" @click.prevent="$store.location.selectCity(c)">
              <span x-text="(window.CURRENT_LOCALE === 'zh-CN' ? (c.name_zh || c.name) : c.name) + (c.country ? ', ' + c.country : '')"></span>
            </a></li>
          </template>
        </ul>
        <div class="mt-2 pt-2 border-t border-base-300" x-show="$store.location.searchResults.length === 0 && !$store.location.searchLoading">
          <span class="text-xs opacity-50" x-text="$store.locale.t('location.popular')">Popular</span>
          <div class="flex flex-wrap gap-1 mt-1">
            <template x-for="c in $store.location.popularCities" :key="c.name">
              <button class="btn btn-xs btn-ghost" @click="$store.location.selectCity(c)" x-text="window.CURRENT_LOCALE === 'zh-CN' ? (c.name_zh || c.name) : c.name"></button>
            </template>
          </div>
        </div>
      </div>
    </div>
    <!-- lang switcher -->
    <div class="dropdown dropdown-end max-lg:hidden" @click.outside="dropdown = null">
      <button class="btn btn-ghost btn-sm text-lg" @click="dropdown = dropdown === 'lang' ? null : 'lang'" aria-label="Switch language">🌐</button>
      <ul x-show="dropdown === 'lang'" class="dropdown-content menu menu-sm bg-base-200 rounded-box shadow mt-2 z-50 w-32">
        <li><a href="#" @click.prevent="switchLocale('en')">English</a></li>
        <li><a href="#" @click.prevent="switchLocale('zh-CN')">中文</a></li>
      </ul>
    </div>
    <!-- theme toggle -->
    <button class="btn btn-ghost btn-sm text-lg max-lg:hidden"
            @click="$store.theme.toggle()"
            aria-label="Toggle theme">
      <span x-show="!$store.theme.dark">🌙</span>
      <span x-show="$store.theme.dark">☀️</span>
    </button>
    <!-- auth -->
    <template x-if="!$store.auth || !$store.auth.id">
      <a href="/{{ site.locale }}/login" class="btn btn-ghost btn-sm max-lg:hidden" x-text="$store.locale.t('nav.login')">Login</a>
    </template>
    <template x-if="$store.auth && $store.auth.id">
      <div class="max-lg:hidden">
        {% include "user-menu.njk" %}
      </div>
    </template>
    <!-- mobile toggle -- fatetell-style hamburger icon -->
    <button class="btn btn-ghost btn-sm lg:hidden p-1" @click="$store.ui.mobileOpen = !$store.ui.mobileOpen" aria-label="Toggle menu">
      <svg width="24" height="16" viewBox="0 0 28 17" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="28" height="3" rx="1.5" fill="currentColor"/>
        <rect y="7" width="28" height="3" rx="1.5" fill="currentColor"/>
        <rect y="14" width="28" height="3" rx="1.5" fill="currentColor"/>
      </svg>
    </button>
  </div>
</nav>

{% include "navbar-mobile.njk" %}
</div>
