{% if concord %}
<div class="bg-base-200 rounded-box shadow-sm mb-6 px-6 py-5 text-center">
  <p class="text-3xl font-bold tracking-wide"
     :class="{
       'text-success': {{ concordBadgeClass }}.includes('success'),
       'text-error': {{ concordBadgeClass }}.includes('error'),
       'text-base-content/50': {{ concordBadgeClass }}.includes('ghost'),
     }"
     x-text="{{ concord }}"></p>
  <p class="text-sm text-base-content/60 mt-2 max-w-md mx-auto" x-text="{{ concordDesc }}"></p>
</div>
{% endif %}
<div class="grid sm:grid-cols-2 gap-6{% if gridClass %} {{ gridClass }}{% endif %}">
  {% set badge = badgeA %}{% set label = labelA %}{% set idText = idTextA %}
  {% set chartId = chartIdA %}{% set influencerLabel = influencerA %}{% set deltaItems = deltaA %}
  {% include "bond-card.njk" %}
  {% set badge = badgeB %}{% set label = labelB %}{% set idText = idTextB %}
  {% set chartId = chartIdB %}{% set influencerLabel = influencerB %}{% set deltaItems = deltaB %}
  {% include "bond-card.njk" %}
</div>
