<!-- Mingli Four Pillars Chart Result -->
<div class="card bg-base-200 shadow-lg mb-8">
  <div class="card-body">

    <!-- ═══ Day Master Hero ═══ -->
    <div class="text-center mb-6 pb-6 border-b border-base-300">
      <div class="text-sm text-base-content/50 mb-2" x-text="$store.locale.t('mingli.bazi.dayMaster')">Day Master</div>
      <div class="text-5xl font-bold mb-2" x-text="formatStem(chart.day_master)"></div>
      <div class="text-lg font-semibold mb-1" x-text="window.MINGLI_TEMPLATES?.day_masters?.[String(chart.day_master)]?.name || ''"></div>
      <p class="text-sm text-base-content/70 leading-relaxed max-w-lg mx-auto" x-text="window.MINGLI_TEMPLATES?.day_masters?.[String(chart.day_master)]?.portrait || ''"></p>
    </div>

    <!-- ═══ Five Element Count ═══ -->
    <h3 class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-3" x-text="$store.locale.t('mingli.bazi.elementCount')">Element Count</h3>
    <div class="space-y-1.5 mb-6">
      <template x-for="el in [1,2,3,4,5]" :key="el">
        <div class="flex items-center gap-2 text-xs">
          <span class="w-6 text-right font-medium" x-text="formatElement(el)"></span>
          <div class="flex-1 h-2 rounded-full bg-base-300">
            <div class="h-2 rounded-full transition-all duration-500"
                 :style="{width: chart.max_elem_count ? (chart.element_count[el]||0) / chart.max_elem_count * 100 + '%' : '0%', background: baziElemColor(el)}"></div>
          </div>
          <span class="w-6 text-right tabular-nums text-base-content/70" x-text="chart.element_count[el] || 0"></span>
        </div>
      </template>
    </div>

    <!-- ═══ Four Pillars ═══ -->
    <h3 class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-3" x-text="$store.locale.t('mingli.bazi.chartTitle')">Four Pillars</h3>
    <div class="grid grid-cols-4 gap-2 mb-6">
      <template x-for="(p, i) in chart.pillars" :key="i">
        <div class="text-center p-3 bg-base-100 rounded-lg space-y-1">
          <div class="text-xs text-base-content/50" x-text="[$store.locale.t('mingli.bazi.yearPillar'), $store.locale.t('mingli.bazi.monthPillar'), $store.locale.t('mingli.bazi.dayPillar'), $store.locale.t('mingli.bazi.hourPillar')][i]"></div>
          <div class="text-2xl font-bold" x-text="formatPillar(p.stem, p.branch)"></div>
          <div class="text-xs text-base-content/60" x-text="chart.na_yin[i]"></div>
          <div class="text-xs text-base-content/50" x-text="formatHiddenStems(chart.hidden_stems[i])"></div>
          <div class="text-xs text-base-content/50" x-text="chart.ten_gods[i] ? chart.ten_gods[i][0] : ''"></div>
          <div class="text-xs text-base-content/50" x-text="chart.ten_gods[i] ? chart.ten_gods[i][1] : ''"></div>
        </div>
      </template>
    </div>

    <!-- ═══ Solar Time ═══ -->
    <div class="text-sm text-base-content/50 mb-4" x-text="$store.locale.t('mingli.bazi.solarTime') + ': ' + fmtSolarTime(chart.solar_time)"></div>

    <!-- ═══ Life Stages ═══ -->
    <h3 class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-2" x-text="$store.locale.t('mingli.bazi.lifeStages')">Life Stages (十二长生)</h3>
    <div class="grid grid-cols-4 md:grid-cols-6 gap-2 mb-6">
      <template x-for="s in chart.life_stages" :key="s.name">
        <div class="text-center p-2 bg-base-100 rounded">
          <div class="text-xs text-base-content/60" x-text="s.name"></div>
          <div class="font-medium" x-text="formatBranch(s.branch)"></div>
        </div>
      </template>
    </div>

    <!-- ═══ Big Fortune ═══ -->
    <h3 class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-2" x-text="$store.locale.t('mingli.bazi.bigFortune')">Big Fortune (大运)</h3>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm mb-1">
      <span class="text-base-content/60" x-text="$store.locale.t('mingli.bazi.startAge') + ': ' + chart.big_fortune.start_age"></span>
      <span class="text-base-content/60" x-text="$store.locale.t('mingli.bazi.direction') + ': ' + chart.big_fortune.direction"></span>
    </div>
    <div class="flex flex-wrap gap-2">
      <template x-for="(p, i) in chart.big_fortune.pillars" :key="i">
        <div class="badge badge-outline" x-text="formatPillar(p.stem, p.branch)"></div>
      </template>
    </div>

  </div>
</div>
