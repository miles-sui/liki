<div class="dropdown dropdown-end" x-data="userMenu()" @click.outside="open = false">
  <button class="btn btn-ghost btn-sm" @click="open = !open" aria-label="User menu">
    <span x-text="$store.auth.name"></span>
    <svg class="w-3 h-3 ml-1 opacity-50" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
  </button>
  <ul x-show="open" class="dropdown-content menu menu-sm bg-base-200 rounded-box shadow mt-2 z-50 w-48">
    <li class="menu-title px-4 py-1 flex items-center gap-2" x-show="$store.auth.isSupporter">
      <span class="badge badge-accent badge-sm" x-text="$store.locale.t('donate.supporterBadge')">Supporter</span>
    </li>
    <li><a :href="'/' + $store.locale.current + '/profile/' + $store.auth.name" x-text="$store.locale.t('nav.profile')">My Profile</a></li>
    <li><a :href="localePath('/settings')" @click="open = false" x-text="$store.locale.t('profile.settings')">Settings</a></li>
    <li class="border-t border-base-300 my-1"></li>
    <li><button @click="open = false; $store.auth.logout()" x-text="$store.locale.t('me.logout')">Logout</button></li>
  </ul>
</div>
