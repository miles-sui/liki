<div class="card bg-base-200 shadow-sm">
  <div class="card-body items-center text-center p-7">
    <div id="{{ radarId }}" role="img" style="width:{{ radarSize | default('200px') }};height:{{ radarSize | default('200px') }};margin:0 auto"></div>
    <div class="badge badge-outline badge-sm mb-1" x-text="{{ badge }}"></div>
    <h3 class="text-xl font-bold mb-0.5" x-text="{{ label }}"></h3>
    <p class="text-sm text-base-content/50 mb-1" x-text="{{ idText }}"></p>
    {% if desc %}<p class="text-sm text-base-content/70 italic" x-text="{{ desc }}"></p>{% endif %}
    <a :href="'/' + $store.locale.current + '/types/' + {{ idText }}" class="text-xs link link-hover mt-1 inline-block" x-text="$store.locale.t('types.detail.learnMore')">Learn more →</a>
    {% include "element-bars.njk" %}
  </div>
</div>
