<!-- _footer.html -->
<footer class="footer px-6 lg:px-14 py-14 bg-base-200 text-base-content/60 {{ footerCls | default('') }} border-t border-base-300">
  <aside>
    <p>
      {% include "logo.njk" %}
    </p>
    <p class="text-sm" x-text="$store.locale.t('footer.tagline')">Find your true type. A five-element framework.</p>
    <p class="text-sm mt-2">© 2026</p>
  </aside>
  <nav>
    <h6 class="footer-title text-base-content/60" x-text="$store.locale.t('footer.explore')">Explore</h6>
    <a href="/{{ site.locale }}/types" class="link link-hover text-sm" x-text="$store.locale.t('nav.types')">25 Types</a>
    <a href="/{{ site.locale }}/assess" class="link link-hover text-sm" x-text="$store.locale.t('nav.assess')">Assess</a>
  </nav>
  <nav>
    <h6 class="footer-title text-base-content/60">{% if site.locale == 'zh-CN' %}工具{% else %}Tools{% endif %}</h6>
    <a href="/{{ site.locale }}/mingli/bazi" class="link link-hover text-sm">{% if site.locale == 'zh-CN' %}八字排盘{% else %}Mingli Chart{% endif %}</a>
    <a href="/{{ site.locale }}/mingli/bazi/liunian" class="link link-hover text-sm">{% if site.locale == 'zh-CN' %}流年运势{% else %}Yearly Fortune{% endif %}</a>
    <a href="/{{ site.locale }}/qiming/baobao" class="link link-hover text-sm">{% if site.locale == 'zh-CN' %}宝宝起名{% else %}Baby Naming{% endif %}</a>
    <a href="/{{ site.locale }}/hehun/lianai" class="link link-hover text-sm">{% if site.locale == 'zh-CN' %}恋爱匹配{% else %}Love Match{% endif %}</a>
    <a href="/{{ site.locale }}/zeri/jiehun" class="link link-hover text-sm">{% if site.locale == 'zh-CN' %}结婚择日{% else %}Wedding Dates{% endif %}</a>
    <a href="/{{ site.locale }}/zhiye/gaokao" class="link link-hover text-sm">{% if site.locale == 'zh-CN' %}高考选专业{% else %}College Major{% endif %}</a>
    <a href="/{{ site.locale }}/qiming" class="link link-hover text-sm">{% if site.locale == 'zh-CN' %}起名取名{% else %}Naming{% endif %}</a>
    <a href="/{{ site.locale }}/hehun" class="link link-hover text-sm">{% if site.locale == 'zh-CN' %}关系分析{% else %}Relationships{% endif %}</a>
    <a href="/{{ site.locale }}/zeri" class="link link-hover text-sm">{% if site.locale == 'zh-CN' %}择日择吉{% else %}Date Selection{% endif %}</a>
  </nav>
  <nav>
    <h6 class="footer-title text-base-content/60" x-text="$store.locale.t('footer.about')">About</h6>
    <a href="/{{ site.locale }}/about" class="link link-hover text-sm" x-text="$store.locale.t('nav.about')">About</a>
    <a href="/{{ site.locale }}/faq" class="link link-hover text-sm" x-text="$store.locale.t('nav.faq')">FAQ</a>
  </nav>
  <nav>
    <h6 class="footer-title text-base-content/60" x-text="$store.locale.t('footer.support')">Support</h6>
    <a href="/{{ site.locale }}/donate" class="link link-hover text-sm" x-text="$store.locale.t('footer.donateLink')">Donate</a>
  </nav>
  <nav>
    <h6 class="footer-title text-base-content/60" x-text="$store.locale.t('footer.legal')">Legal</h6>
    <a href="/{{ site.locale }}/privacy" class="link link-hover text-sm" x-text="$store.locale.t('footer.privacy')">Privacy</a>
    <a href="/{{ site.locale }}/terms" class="link link-hover text-sm" x-text="$store.locale.t('footer.terms')">Terms</a>
    <a href="/{{ site.locale }}/cookies" class="link link-hover text-sm" x-text="$store.locale.t('footer.cookies')">Cookies</a>
  </nav>
</footer>
