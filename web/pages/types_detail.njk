---
layout: base.njk
pagination:
  data: types
  size: 1
  alias: type
permalink: "{{ site.locale }}/types/{{ type.id }}/index.html"
eleventyComputed:
  title: "{{ type.label }}"
  description: "{{ type.tagline }}"
---
<div class="max-w-3xl mx-auto px-4 py-10" x-data="{ type: {{ type | dump }} }">

  {# === Header === #}
  <div class="text-center mb-12">
    <div class="flex gap-2 justify-center mb-3">
      <span class="badge badge-lg" :style="{background: elementColor(type.id[0]) + '20', color: elementColor(type.id[0])}">
        <span x-text="window.ELEMENT_NAMES[type.id[0]]"></span>
      </span>
      <template x-if="type.id[1]">
        <span class="badge badge-lg" :style="{background: elementColor(type.id[1]) + '20', color: elementColor(type.id[1])}">
          <span x-text="window.ELEMENT_NAMES[type.id[1]]"></span>
        </span>
      </template>
    </div>
    <h1 class="text-4xl font-bold mb-2" x-text="type.label"></h1>
    <p class="text-lg text-base-content/60 italic mb-4" x-text="type.tagline"></p>
  </div>

  {# === Portrait (expanded description) === #}
  {% set condition = 'type.portrait' %}{% set titleKey = 'types.detail.portrait' %}{% set binding = 'type.portrait' %}{% include "type-section.njk" %}

  {# === Strengths & Blindspots === #}
  <template x-if="type.strengths && type.strengths.length">
    <div class="card bg-base-100 shadow-sm mb-8">
      <div class="card-body">
        <h2 class="card-title text-xl mb-4" x-text="$store.locale.t('types.detail.strengths')">Strengths & Blindspots</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold text-success mb-2 text-sm" x-text="$store.locale.t('types.detail.strengthsTitle')">Strengths</h3>
            <ul class="space-y-1">
              <template x-for="s in type.strengths" :key="s">
                <li class="flex items-start gap-2 text-sm">
                  <span class="text-success mt-0.5">+</span>
                  <span x-text="s"></span>
                </li>
              </template>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-error mb-2 text-sm" x-text="$store.locale.t('types.detail.blindspotsTitle')">Blindspots</h3>
            <ul class="space-y-1">
              <template x-for="b in type.blindspots" :key="b">
                <li class="flex items-start gap-2 text-sm">
                  <span class="text-error mt-0.5">−</span>
                  <span x-text="b"></span>
                </li>
              </template>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </template>

  {# === Interactions === #}
  <template x-if="type.interactions && type.interactions.length">
    <div class="card bg-base-100 shadow-sm mb-8">
      <div class="card-body">
        <h2 class="card-title text-xl mb-4" x-text="$store.locale.t('types.detail.interactions')">How You Interact</h2>
        <p class="text-sm text-base-content/50 mb-5" x-text="$store.locale.t('types.detail.interactionsDesc')">Your element interacts differently with each of the five pure types.</p>
        <div class="space-y-3">
          <template x-for="ix in type.interactions" :key="ix.with">
            <div class="card bg-base-200">
              <div class="card-body p-4 flex flex-row items-start gap-3">
                <a :href="'/' + $store.locale.current + '/types/' + ix.with" class="badge badge-lg shrink-0 hover:opacity-80 transition-opacity" :style="{background: elementColor(ix.with) + '20', color: elementColor(ix.with)}">
                  <span x-text="window.ELEMENT_NAMES[ix.with]"></span>
                </a>
                <div class="flex-1">
                  <p class="text-sm leading-relaxed" x-text="ix.summary"></p>
                </div>
              </div>
            </div>
          </template>
        </div>
      </div>
    </div>
  </template>

  {# === Classical Roots === #}
  {% set condition = 'type.classical' %}{% set titleKey = 'types.detail.classical' %}{% set binding = 'type.classical' %}{% include "type-section.njk" %}

  {# === Representative Figures === #}
  <template x-if="type.figures && type.figures.length">
    <div class="card bg-base-100 shadow-sm mb-8">
      <div class="card-body">
        <h2 class="card-title text-xl mb-3" x-text="$store.locale.t('types.detail.figures')">Representative Figures</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <template x-for="fig in type.figures" :key="fig.name">
            <div class="card bg-base-200">
              <div class="card-body p-4">
                <div class="flex items-center gap-2 mb-2">
                  <h3 class="font-bold" x-text="fig.name"></h3>
                  <span class="badge badge-sm badge-outline text-xs" x-text="fig.domain"></span>
                </div>
                <p class="text-xs text-base-content/50 mb-2" x-text="fig.bio"></p>
                <p class="text-sm text-base-content/70 leading-relaxed" x-text="fig.desc"></p>
              </div>
            </div>
          </template>
        </div>
      </div>
    </div>
  </template>

  {# === Growth === #}
  {% set condition = 'type.growth' %}{% set titleKey = 'types.detail.growth' %}{% set binding = 'type.growth' %}{% include "type-section.njk" %}

  {# === Short desc (fallback) === #}
  <template x-if="!type.portrait">
    <div class="card bg-base-100 shadow-sm mb-8">
      <div class="card-body">
        <p class="text-base-content/70 leading-relaxed" x-text="type.desc"></p>
      </div>
    </div>
  </template>

  {# === CTA === #}
  <div class="text-center mt-12">
    <p class="text-base-content/60 text-sm mb-4" x-text="$store.locale.t('types.detail.cta.text')">Not sure where to start? Take the assessment to find your type.</p>
    <a href="/{{ site.locale }}/assess" class="btn btn-primary btn-lg" x-text="$store.locale.t('types.cta.btn')">Take Assessment</a>
  </div>
</div>
