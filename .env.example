# Cloudflare API Token — Zone:DNS:Edit permission on tokflux.com
CF_API_TOKEN=

# JWT signing secret — 32+ random characters
JWT_SECRET=

# Resend API Key + From address (resend.com)
RESEND_API_KEY=
RESEND_FROM=
EMAIL_FROM=noreply@liki.hk

# Tencent SES (future)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-hongkong
TENCENT_FROM=

# Dodo Payments (国际卡)
DODO_API_KEY=
DODO_WEBHOOK_KEY=
DODO_TEST_MODE=1
DODO_PRODUCT_CHART=
DODO_PRODUCT_BOND=
DODO_PRODUCT_NAMING=

# 虎皮椒支付 (微信/支付宝)
XUNHU_APPID=
XUNHU_APPSECRET=

# DeepSeek
DEEPSEEK_API_KEY=

# Domain — per deployment target
DOMAIN_US=liki.hk
DOMAIN_CN=liki.tokflux.com
RETURN_URL_US=https://liki.hk
RETURN_URL_CN=https://liki.tokflux.com
