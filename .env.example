# Cloudflare API Token — Zone:DNS:Edit permission on 25types.com
CF_API_TOKEN=

# JWT signing secret — 32+ random characters
JWT_SECRET=

# --- Email provider: "resend" or "tencent" ---
EMAIL_PROVIDER=resend

# Resend (resend.com)
RESEND_API_KEY=

# Tencent SES (cloud.tencent.com)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-hongkong
TENCENT_FROM=

# Dodo Payments
DODO_API_KEY=
DODO_WEBHOOK_KEY=
DODO_TEST_MODE=1
DODO_PRODUCT_DONATION=

# Common
EMAIL_FROM=noreply@25types.com
